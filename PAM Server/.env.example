# Database
# SQLite (development): sqlite+aiosqlite:///./pam.db
# PostgreSQL (production): postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./pam.db

# JWT Tokens — generate unique random values for production
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Agent API Key — shared secret between PAM Server and Tenant Agent
AGENT_API_KEY=your_agent_api_key_here

# CORS origin for frontend (React dev server or deployed URL)
FRONTEND_URL=http://localhost:5173

# SSH key path for terminal sessions (default Linux user)
SSH_KEY_PATH=/home/administrator/.ssh/id_rsa

# Server port (optional, defaults to 3001)
PORT=3001
