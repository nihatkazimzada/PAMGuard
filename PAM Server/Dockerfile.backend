FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir fastapi uvicorn[standard] sqlalchemy aiosqlite bcrypt python-jose[cryptography] websockets asyncssh python-multipart aiofiles httpx

COPY backend-python/ .

EXPOSE 3001

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "3001"]
