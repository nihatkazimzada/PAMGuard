# PAM Tenant Agent — Environment Configuration
# Copy this to .env (or config.yaml) and fill in your values.
# Never commit the real .env file.

# PAM Server connection
PAM_SERVER_URL=http://<pam-server-ip>:3001
PAM_API_KEY=your_api_key_here
PAM_COMPANY_ID=your_company_id_here
PAM_TENANT_NAME=your_tenant_name_here

# Agent HTTP listener
PAM_AGENT_PORT=8800
PAM_AGENT_BIND_ADDR=0.0.0.0

# Heartbeat interval (seconds)
PAM_HEARTBEAT_INTERVAL=25

# PAM Server IP (for firewall rules and request validation)
PAM_SERVER_IP=<pam-server-ip>

# Agent config file path (default: /etc/pam-agent/config.yaml)
# PAM_AGENT_CONFIG=/etc/pam-agent/config.yaml

# Agent log file path (default: /var/log/pam-agent.log)
# PAM_AGENT_LOG=/var/log/pam-agent.log
